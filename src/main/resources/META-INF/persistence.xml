<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">
    <!--
    Una "unidad de persistencia" agrupa la configuración de una BBDD.
    Puedes tener varias si tu app conecta a varias bases de datos.
    -->
    <persistence-unit name="smt-pu" transaction-type="RESOURCE_LOCAL">
        <!-- Hibernate como proveedor JPA -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <!-- Entidades mapeadas -->
        <class>entities.Viajero</class>
        <class>entities.Viaje</class>

        <properties>
            <!-- Conexión -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/smt"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="Jaroso_26"/>
            <!-- Dialecto Hibernate -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>
            <!-- Gestión del esquema -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- SQL en consola -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>